# Ignore Frontend completely (isne hi 200MB kiya hua hai)
frontend/
node_modules/
**/node_modules/

# Ignore Python environments and cache
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore Git and Environment secrets
.git/
.gitignore
.env

# Ignore OS specific files
.DS_Store
Thumbs.db

# Ignore Docker files themselves inside context
Dockerfile
docker-compose.yml
.dockerignore